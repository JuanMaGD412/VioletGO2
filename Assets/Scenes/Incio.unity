--- !u!114 &1165884087
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1165884084}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "La <b><color=#FFD166>L\xEDnea Alma</color></b> es un <b><color=#FFD166>servicio
    gratuito de atenci\xF3n telef\xF3nica</color></b> para acompa\xF1ar en <b><color=#FFD166>salud
    mental</color></b> y orientar en casos de <b><color=#FFD166>Violencias Basadas
    en G\xE9nero</color></b>. Est\xE1 disponible las <b><color=#FFD166>24 horas del
    d\xEDa, los siete d\xEDas de la semana</color></b>.\n\nOfrece <b><color=#FFD166>asesor\xEDa,
    acompa\xF1amiento y apoyo emocional profesional</color></b> para la comunidad
    universitaria de la <b><color=#FFD166>Universidad de Antioquia</color></b>, en
    sus campus ubicados en <b><color=#FFD166>Medell\xEDn y las regiones donde la
    Universidad tiene presencia</color></b>. Es un espacio de <b><color=#FFD166>atenci\xF3n
    confidencial y seguro</color></b>.\n\nMarca la <b><color=#FFD166>L\xEDnea Alma</color></b>
    desde un tel\xE9fono fijo o celular al n\xFAmero <b><color=#FFD166>018000423874</color></b>
    o escribe a trav\xE9s de <b><color=#FFD166>WhatsApp: 3054336317</color></b>.\n\n<b><color=#FFD166>\xA1Te
    escuchamos, te orientamos!</color></b> \nAl llamar, marca la opci\xF3n seg\xFAn
    tu necesidad: \n<b><color=#FFD166>Marca 1</color></b>: para recibir atenci\xF3n
    por temas de salud mental. \n<b><color=#FFD166>Marca 2</color></b>: para recibir
    orientaci\xF3n y atenci\xF3n ante violencias basadas en g\xE9nero. \n<b><color=#FFD166>Marca
    3</color></b>: para recibir orientaci\xF3n si te han se\xF1alado como responsable
    de alg\xFAn tipo de violencia o discriminaci\xF3n basada en g\xE9nero."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
