  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "CR\xC9DITOS\n\nEsta App <b><color=#FFD166>APP VIOLETA GO: Jugamos para
    transformar</color></b> fue creada como producto del proyecto denominado <b><color=#FFD166>PREVENCI\xD3N
    Y DETECCI\xD3N DE VBG POR UNA UDEA LIBRE DE VIOLENCIAS</color></b>.\n\nSu desarrollo
    estuvo a cargo de un <b><color=#FFD166>equipo multidisciplinar</color></b>\nde
    los campus <b><color=#FFD166>Yarumal, Puerto Berr\xEDo y Medell\xEDn</color></b>,
    con los recursos de la convocatoria\n<b><color=#FFD166> PROMOTORES DEL BIENESTAR
    2025-2026</color></b>.\n\n<b><color=#FFD166>Equipo del campus de Puerto Berr\xEDo</color></b>\nDiana
    Patricia Restrepo Ruiz\nDaniel Esteban Guti\xE9rrez Morales\n\n<b><color=#FFD166>Equipo
    del campus de Yarumal</color></b>\nLined del Carmen Areiza Saldarriaga\nClaudia
    Juliana Correa\nSandar Milena Cardona Morales\nAlex Enrique Renter\xEDa Moreno\nLaura
    Melissa Carmona M\xFAnera\nAlba Luc\xEDa P\xE9rez Osorio\nAlejandra Restrepo
    G\xF3mez\n\n<b><color=#FFD166>Equipo de Ingenier\xEDa</color></b>\nSemillero
    de videojuegos SEVIJU 317 del Grupo de investigaci\xF3n ITOS\nEstudiante Juan
    Manuel Grandet Duarte\nEstudiante Juan Manuel Vera Osorio\nProfesor Diana Margot
    L\xF3pez Herrera\n\n<b><color=#FFD166>Agradecimientos</color></b>\nAl Sistema
    Universitario de Bienestar de la UDEA"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 2e498d1c8094910479dc3e1b768306a4, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 2e498d1c8094910479dc3e1b768306a4, type: 2}
