  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Te damos la bienvenida a\n<b><color=#FFD166>VIOLETA GO: Jugamos para transformar</color></b>,
    una iniciativa de los campus <b><color=#FFD166>Yarumal y Puerto Berr\xEDo de
    la Universidad de Antioquia</color></b>, creada para acompa\xF1ar a la comunidad
    universitaria en la <b><color=#FFD166>prevenci\xF3n y detecci\xF3n de las Violencias
    Basadas en G\xE9nero (VBG)</color></b> en el contexto universitario.\n\nDesarrollada
    en el marco de la <b><color=#FFD166>Convocatoria Promotores del Bienestar 2025\u20132026</color></b>
    y basada en el <b><color=#FFD166>Protocolo Ruta Violeta (2023)</color></b>, <b><color=#FFD166>VIOLETA
    GO</color></b> te invita a aprender a trav\xE9s de <b><color=#FFD166>retos, desaf\xEDos,
    din\xE1micas y contenidos de valor</color></b> que te ayudar\xE1n a <b><color=#FFD166>reconocer
    e identificar las VBG</color></b>, <b><color=#FFD166>conocer las rutas de atenci\xF3n
    de la Universidad</color></b> y <b><color=#FFD166>actuar de manera oportuna</color></b>.\n\nEn
    <b><color=#FFD166>VIOLETA GO</color></b>, cada interacci\xF3n suma a la construcci\xF3n
    de una <b><color=#FFD166>cultura universitaria de respeto, cuidado y convivencia</color></b>.
    Empieza a jugar y a aprender: <b><color=#FFD166>lo que haces aqu\xED puede cambiar
    la forma en que vivimos en la universidad</color></b>.\n\n<b><color=#FFD166>Copyright
    UDEA 2026</color></b>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
